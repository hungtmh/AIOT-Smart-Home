SUPABASE_DB_URL=jdbc:postgresql://aws-0-your-region.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_USERNAME=postgres.your-project-ref
SUPABASE_DB_PASSWORD=your-supabase-database-password
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_JWKS_URI=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

MQTT_BROKER_URI=tcp://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_COMMAND_TOPIC_PATTERN=aiot/esp32-s3/device/%s/set
MQTT_STATE_TOPIC_PATTERN=aiot/esp32-s3/device/%s/state
MQTT_TELEMETRY_TOPIC=aiot/esp32-s3/telemetry

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
